# Local dev: http://localhost:3001 — Production: your deployed API with https:// (must match where /quiz-images is served).
REACT_APP_API_URL=http://localhost:3001

# Deploy WhoAmINFT from blockchain/ to Polygon Amoy, then paste the deployed address (0x + 40 hex chars).
# Restart npm start after editing — Create React App reads .env only at startup.
REACT_APP_NFT_CONTRACT_ADDRESS=
