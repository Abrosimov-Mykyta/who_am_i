# Server Configuration
PORT=3001
HOST=localhost

# Optional: absolute image URLs in API JSON (for bots). If unset, API returns path-only /quiz-images/... and the React app uses REACT_APP_API_URL.
# Example: https://who-am-i-backend-xxxx.onrender.com
# API_PUBLIC_URL=

# Hugging Face API Key
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/who-am-i

# IPFS Configuration
IPFS_NODE=https://ipfs.infura.io:5001
IPFS_GATEWAY=https://ipfs.io/ipfs

# NFT Configuration
NFT_CONTRACT_ADDRESS=your_contract_address_here
NETWORK=mumbai 