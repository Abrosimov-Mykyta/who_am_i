# Server Configuration
PORT=3001
HOST=localhost

# Base URL browsers use to load /quiz-images (NFT metadata). Use LAN IP if testing on a phone.
API_PUBLIC_URL=http://localhost:3001

# Hugging Face API Key
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/who-am-i

# IPFS Configuration
IPFS_NODE=https://ipfs.infura.io:5001
IPFS_GATEWAY=https://ipfs.io/ipfs

# NFT Configuration
NFT_CONTRACT_ADDRESS=your_contract_address_here
NETWORK=mumbai 